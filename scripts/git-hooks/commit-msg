#!/bin/bash

# SmartTicket Commit Message Hook
# This hook validates commit messages to ensure they follow conventional commit format

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Print colored output
print_status() {
    echo -e "${BLUE}[COMMIT-MSG]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[COMMIT-MSG]${NC} ✓ $1"
}

print_warning() {
    echo -e "${YELLOW}[COMMIT-MSG]${NC} ⚠ $1"
}

print_error() {
    echo -e "${RED}[COMMIT-MSG]${NC} ✗ $1"
}

# Get the commit message file
commit_msg_file="$1"

if [ -z "$commit_msg_file" ]; then
    print_error "No commit message file provided"
    exit 1
fi

# Read the commit message
commit_msg=$(cat "$commit_msg_file")

# Check for empty commit message
if [ -z "$commit_msg" ]; then
    print_error "Commit message cannot be empty"
    exit 1
fi

# Get the first line (subject)
subject=$(echo "$commit_msg" | head -n 1)

# Check subject length (should be 50-72 characters)
subject_length=${#subject}
if [ "$subject_length" -gt 72 ]; then
    print_error "Subject line is too long ($subject_length characters, max 72)"
    print_status "Keep subject line under 72 characters"
    exit 1
fi

if [ "$subject_length" -lt 10 ]; then
    print_error "Subject line is too short ($subject_length characters, min 10)"
    print_status "Use a descriptive subject line"
    exit 1
fi

# Check if subject doesn't end with a period
if [[ "$subject" == *. ]]; then
    print_error "Subject line should not end with a period"
    exit 1
fi

# Check for conventional commit format
# Format: type(scope): description
conventional_types="feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert|bump"

if ! echo "$subject" | grep -E "^($conventional_types)(\(.+\))?: .+" > /dev/null; then
    print_error "Commit message doesn't follow conventional commit format"
    print_status "Format: type(scope): description"
    print_status ""
    print_status "Types:"
    echo "  feat:     New feature"
    echo "  fix:      Bug fix"
    echo "  docs:     Documentation changes"
    echo "  style:    Code style changes (formatting, etc.)"
    echo "  refactor: Code refactoring"
    echo "  test:     Test additions or changes"
    echo "  chore:    Maintenance tasks"
    echo "  perf:     Performance improvements"
    echo "  ci:       CI/CD changes"
    echo "  build:    Build system changes"
    echo "  revert:   Revert previous commit"
    echo "  bump:     Version bump"
    print_status ""
    print_status "Examples:"
    echo "  feat(auth): add JWT token validation"
    echo "  fix(api): resolve memory leak in ticket processing"
    echo "  docs(readme): update installation instructions"
    echo "  test(tickets): add integration tests for ticket lifecycle"
    exit 1
fi

# Extract type and scope
type=$(echo "$subject" | sed -E "s/^($conventional_types)(\(.+\))?: .+/\1/")
scope=$(echo "$subject" | sed -E "s/^($conventional_types)(\(.+\))?: .+/\2/" | sed 's/[()]//g')

print_success "Conventional commit format validated"
print_status "Type: $type"
if [ -n "$scope" ]; then
    print_status "Scope: $scope"
fi

# Additional checks for specific types

# Check if breaking change is properly indicated
if echo "$commit_msg" | grep -q "BREAKING CHANGE:"; then
    if [ "$type" != "feat" ] && [ "$type" != "refactor" ]; then
        print_warning "Breaking changes should typically be marked as 'feat' or 'refactor'"
    fi
    print_status "Breaking change detected"
fi

# Check for WIP commits
if echo "$subject" | grep -qi "wip\|work in progress\|todo"; then
    print_warning "This appears to be a work-in-progress commit"
    print_status "Consider finishing the work before committing"
fi

# Check for fix commits that reference issues
if [ "$type" = "fix" ]; then
    if echo "$commit_msg" | grep -qi "fixes\|closes\|resolves"; then
        print_status "Fix commit references an issue - good practice!"
    else
        print_warning "Consider referencing the issue this fix resolves"
        print_status "Example: fix: resolve memory leak (fixes #123)"
    fi
fi

# Check body length if present
body=$(echo "$commit_msg" | sed '1d' | sed '/^$/q')
if [ -n "$body" ]; then
    # Check for blank line between subject and body
    second_line=$(echo "$commit_msg" | sed -n '2p')
    if [ -n "$second_line" ]; then
        print_error "Add blank line between subject and body"
        exit 1
    fi

    # Check body line length (should wrap at 72 characters)
    long_lines=$(echo "$body" | awk 'length > 72')
    if [ -n "$long_lines" ]; then
        print_warning "Some lines in commit body exceed 72 characters"
        print_status "Consider wrapping lines at 72 characters for better readability"
    fi
fi

# Check for common anti-patterns

# No "and" in subject (should be separate commits)
if echo "$subject" | grep -qi " and "; then
    print_warning "Subject contains 'and' - consider splitting into separate commits"
fi

# No "temporarily" commits
if echo "$subject" | grep -qi "temporarily\|temp\|temporary"; then
    print_warning "Consider if temporary changes should be committed"
fi

# Check for test-related commits that should include test changes
if [ "$type" = "feat" ] || [ "$type" = "fix" ]; then
    # Check if related test files are staged
    staged_files=$(git diff --cached --name-only)
    has_go_files=false
    has_test_files=false

    for file in $staged_files; do
        if [[ "$file" == *.go ]] && [[ "$file" != *"_test.go" ]]; then
            has_go_files=true
        fi
        if [[ "$file" == *"_test.go" ]]; then
            has_test_files=true
        fi
    done

    if [ "$has_go_files" = true ] && [ "$has_test_files" = false ]; then
        print_warning "Code changes without test changes detected"
        print_status "Consider adding or updating tests"
    fi
fi

print_success "Commit message validation completed successfully!"