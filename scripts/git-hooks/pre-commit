#!/bin/bash

# SmartTicket Pre-commit Hook
# This hook runs various checks before allowing a commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Print colored output
print_status() {
    echo -e "${BLUE}[PRE-COMMIT]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[PRE-COMMIT]${NC} ✓ $1"
}

print_warning() {
    echo -e "${YELLOW}[PRE-COMMIT]${NC} ⚠ $1"
}

print_error() {
    echo -e "${RED}[PRE-COMMIT]${NC} ✗ $1"
}

# Check if we're in the right directory
if [ ! -f "go.mod" ]; then
    print_error "Not in Go project root directory"
    exit 1
fi

print_status "Running pre-commit checks..."

# Staged files check
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    print_status "No Go files staged for commit"
    exit 0
fi

print_status "Found staged Go files:"
echo "$STAGED_GO_FILES"

# 1. Go format check
print_status "Checking Go code formatting..."
if ! command -v gofmt &> /dev/null; then
    print_error "gofmt not found. Please install Go tools."
    exit 1
fi

UNFORMATTED=$(gofmt -l -s $STAGED_GO_FILES)
if [ -n "$UNFORMATTED" ]; then
    print_error "The following files are not properly formatted:"
    echo "$UNFORMATTED"
    print_status "Run 'make fmt' to fix formatting issues"
    exit 1
fi
print_success "Go code formatting check passed"

# 2. Go vet check
print_status "Running go vet..."
if ! go vet ./...; then
    print_error "go vet failed"
    exit 1
fi
print_success "go vet check passed"

# 3. Go imports check
print_status "Checking imports..."
if ! command -v goimports &> /dev/null; then
    print_warning "goimports not found. Skipping import optimization."
else
    IMPORTS_ISSUES=$(goimports -l $STAGED_GO_FILES)
    if [ -n "$IMPORTS_ISSUES" ]; then
        print_error "The following files have import issues:"
        echo "$IMPORTS_ISSUES"
        print_status "Run 'goimports -w' to fix import issues"
        exit 1
    fi
    print_success "Go imports check passed"
fi

# 4. Linting check (optional)
if command -v golangci-lint &> /dev/null; then
    print_status "Running golangci-lint..."
    # Only run linter on staged files and changed packages
    PACKAGES=$(echo "$STAGED_GO_FILES" | xargs dirname | sort -u | sed 's|^|./|' | tr '\n' ' ')
    if [ -n "$PACKAGES" ]; then
        if ! golangci-lint run $PACKAGES; then
            print_error "golangci-lint failed"
            print_status "Run 'make lint-fix' to attempt to fix linting issues"
            exit 1
        fi
    fi
    print_success "golangci-lint check passed"
else
    print_warning "golangci-lint not found. Skipping linting check."
fi

# 5. Unit tests for changed packages
print_status "Running unit tests for changed packages..."
PACKAGES=$(echo "$STAGED_GO_FILES" | xargs dirname | sort -u | sed 's|^|./|' | tr '\n' ' ')
if [ -n "$PACKAGES" ]; then
    if ! go test -short $PACKAGES; then
        print_error "Unit tests failed"
        exit 1
    fi
fi
print_success "Unit tests passed"

# 6. Check for TODO/FIXME comments
print_status "Checking for TODO/FIXME comments..."
TODO_COUNT=$(git diff --cached $STAGED_GO_FILES | grep -E "^\+.*TODO|FIXME" | wc -l || true)
if [ "$TODO_COUNT" -gt 0 ]; then
    print_warning "Found $TODO_COUNT TODO/FIXME comments in staged changes:"
    git diff --cached $STAGED_GO_FILES | grep -E "^\+.*TODO|FIXME" | sed 's/^/  /'
    print_status "Consider addressing these before committing"
fi

# 7. Security check (if gosec is available)
if command -v gosec &> /dev/null; then
    print_status "Running security scan..."
    if ! gosec $STAGED_GO_FILES; then
        print_error "Security scan found issues"
        print_status "Review and fix security issues before committing"
        exit 1
    fi
    print_success "Security scan passed"
else
    print_warning "gosec not found. Skipping security check."
fi

# 8. License header check
print_status "Checking license headers..."
MISSING_LICENSE=0
for file in $STAGED_GO_FILES; do
    if [ -f "$file" ]; then
        # Skip test files and generated files
        if [[ "$file" == *"_test.go" ]] || [[ "$file" == *"mock_"* ]] || [[ "$file" == *"generated"* ]]; then
            continue
        fi

        # Check if file has license header (first 5 lines should contain Copyright)
        if ! head -n 5 "$file" | grep -q "Copyright"; then
            print_error "Missing license header in: $file"
            MISSING_LICENSE=$((MISSING_LICENSE + 1))
        fi
    fi
done

if [ "$MISSING_LICENSE" -gt 0 ]; then
    print_error "Please add license headers to the above files"
    exit 1
fi
print_success "License header check passed"

# 9. Check for sensitive data
print_status "Checking for sensitive data..."
SENSITIVE_PATTERNS=(
    "password\s*=\s*['\"][^'\"]+['\"]"
    "secret\s*=\s*['\"][^'\"]+['\"]"
    "api_key\s*=\s*['\"][^'\"]+['\"]"
    "token\s*=\s*['\"][^'\"]+['\"]"
    "private_key"
    "BEGIN.*PRIVATE KEY"
)

for pattern in "${SENSITIVE_PATTERNS[@]}"; do
    if git diff --cached $STAGED_GO_FILES | grep -E "$pattern" > /dev/null; then
        print_error "Potential sensitive data detected with pattern: $pattern"
        print_error "Please remove or replace with environment variables"
        exit 1
    fi
done
print_success "Sensitive data check passed"

# 10. Build check
print_status "Checking if code builds..."
if ! go build ./...; then
    print_error "Build failed"
    exit 1
fi
print_success "Build check passed"

print_success "All pre-commit checks passed! ✓"
echo ""
print_status "Ready to commit your changes."