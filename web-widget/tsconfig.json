{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "lib": ["ES2018", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "declaration": true
  },
  "include": ["src"]
}
