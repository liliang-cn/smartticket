# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
smartticket
smartticket-*

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage/
coverage.html
coverage.out

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work

# Build directories
build/
dist/
bin/

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Project specific — anchored to repo root so nested dirs like
# web/src/features/data/ are not accidentally ignored.
/data/
/data_dev/
/data_test/
/logs/
/backups/
*.db
*.sqlite
*.sqlite3

# Temporary files
*.tmp
*.log
*.bak

# Environment files
.env
.env.local
.env.*.local

# Configuration files (keep examples)
config/config.yaml
config/config.prod.yaml
!config/config.example.yaml
!config/config.dev.yaml.example

# Documentation build
docs/_build/
docs/.doctrees/

# Profiling files
*.prof
cpu.prof
mem.prof

# Security scan files
gosec-report.json
vulncheck-report.json

# Local development
.local/

# Test artifacts
test-results/
test-coverage/

# Node modules (if frontend is included)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build
frontend/build/
frontend/dist/

# Docker volumes
docker-data/
docker-logs/

# Package files
*.deb
*.rpm
*.tar.gz
*.zip

# Auto-generated files
*_generated.go
*.pb.go
*_mock.go

# Make generated files
Makefile.deps

# Release files
release/
releases/

# Cache directories
.cache/
.parcel-cache/

