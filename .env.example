# SmartTicket Environment Configuration
# Copy this file to .env and update with your values:  cp .env.example .env

# ── Secrets (REQUIRED for any real deployment) ───────────────────────────────
# These are read by the binary via the SMARTTICKET_* prefix. Generate strong
# random values once and keep them stable (changing them invalidates sessions
# and orphans encrypted LLM API keys):
#   echo "SMARTTICKET_JWT_SECRET=$(openssl rand -hex 32)" >> .env
#   echo "SMARTTICKET_SECRET_KEY=$(openssl rand -hex 32)" >> .env
SMARTTICKET_JWT_SECRET=
# AES-256 key encrypting LLM provider API keys at rest (32-byte hex):
SMARTTICKET_SECRET_KEY=

# Application Settings
PORT=6533
ENVIRONMENT=development
LOG_LEVEL=debug
GIN_MODE=debug

# Database Settings
DB_PATH=./data/smartticket.db
DB_TYPE=sqlite
DB_MAX_CONNECTIONS=10
DB_MAX_IDLE_CONNS=5

# JWT Settings
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION_TIME=1h
JWT_REFRESH_TIME=24h
JWT_ISSUER=smartticket

# CORS Settings
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST=200

# Redis Settings (optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Settings (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@smartticket.local
EMAIL_ENABLED=false

# File Storage
STORAGE_DATA_PATH=./data
STORAGE_BACKUP_PATH=./backups
STORAGE_TEMP_PATH=./tmp
MAX_FILE_SIZE=52428800

# Security
ENABLE_CSRF=true
ENABLE_CONTENT_TYPE_CHECK=true
MAX_REQUEST_SIZE=10485760

# Monitoring
ENABLE_METRICS=true
METRICS_PATH=/metrics
ENABLE_PPROF=false

# SSL Settings (for production)
SSL_CERT_PATH=
SSL_KEY_PATH=

# LLM Settings (optional)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Development Only
ENABLE_PPROF=true
ENABLE_DEBUG=true